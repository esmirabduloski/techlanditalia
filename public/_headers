# Security headers globali (applicati a tutte le route)
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.stripe.com https://*.trustpilot.com https://www.googletagmanager.com https://www.google-analytics.com https://widget.trustpilot.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.trustpilot.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.stripe.com https://www.google-analytics.com https://*.trustpilot.com https://connector-gateway.lovable.dev https://aedpckxjyyklqwrzrnmg.supabase.co; frame-src https://*.stripe.com https://*.youtube.com https://www.youtube-nocookie.com https://docs.google.com https://drive.google.com https://replit.com https://*.replit.com https://widget.trustpilot.com; media-src 'self' https: blob:; object-src 'none'; base-uri 'self'; form-action 'self';
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(self "https://*.stripe.com")

# Cache long per asset versionati (Vite genera hash nel filename)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache long per immagini
/images/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.png
  Cache-Control: public, max-age=2592000

/favicon.ico
  Cache-Control: public, max-age=2592000

/og-image.png
  Cache-Control: public, max-age=2592000

# Font auto-hosted
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.woff
  Cache-Control: public, max-age=31536000, immutable

# Sitemap e robots: cache breve, devono aggiornarsi
/sitemap.xml
  Cache-Control: public, max-age=3600, must-revalidate

/robots.txt
  Cache-Control: public, max-age=3600, must-revalidate

# HTML: no cache (SPA, deve sempre prendere ultima versione)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# Markdown mirrors per LLM e search engine
/*.md
  Content-Type: text/markdown; charset=utf-8
  Cache-Control: public, max-age=3600
  X-Robots-Tag: index, follow

/llms.txt
  Content-Type: text/markdown; charset=utf-8
  Cache-Control: public, max-age=3600
  X-Robots-Tag: index, follow

/llms-full.txt
  Content-Type: text/markdown; charset=utf-8
  Cache-Control: public, max-age=3600
  X-Robots-Tag: index, follow
